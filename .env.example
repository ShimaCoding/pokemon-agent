GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OR_SITE_URL=https://your-app-url.com
OR_APP_NAME=pokemon-agent

# Security (leave blank to disable for local dev)
API_KEY=                          # Clients must send X-API-Key: <value>; leave blank to disable
ALLOWED_ORIGINS=                  # Comma-separated origins, e.g. https://midominio.com; leave blank for *
MCP_SERVER_URL=                   # Override MCP server URL; leave blank to use default
