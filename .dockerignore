# Git
.git
.gitignore

# Python
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# Virtual environments
.venv/
venv/
env/

# Frontend — node_modules are reinstalled inside the container
frontend/node_modules/
frontend/.vite/

# Pre-built static assets — rebuilt inside the container by the frontend-builder stage
backend/static/
# admin.html is not part of the React build; keep it in context so Dockerfile can restore it
!backend/static/admin.html

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Env files — never bake secrets into the image
.env
.env.local
.env.*.local

# Documentation
README.md
CLAUDE.md
*.md

# IDE / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
